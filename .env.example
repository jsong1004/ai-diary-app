# OpenRouter (https://openrouter.ai) — AI 감성 분석 / 챗봇 / 표지 이미지
VITE_OPENROUTER_API_KEY=sk-or-your-key-here
VITE_OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
# (선택) 표지 이미지 생성 모델 — 비용 발생, 기본 OFF
VITE_OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image
# (선택) 음성 입력 전사 모델 — 무료 오디오 입력 모델
VITE_OPENROUTER_AUDIO_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
