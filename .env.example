# OpenRouter (https://openrouter.ai) — AI 감성 분석 / 챗봇 / 음성 / 표지 이미지
VITE_OPENROUTER_API_KEY=sk-or-your-key-here
# 텍스트 감성 분석/챗봇 모델 (멀티모달: 텍스트·이미지·영상)
VITE_OPENROUTER_MODEL=minimax/minimax-m3
# 음성 입력 전사 모델 (minimax는 오디오 미지원이라 gemini 사용)
VITE_OPENROUTER_AUDIO_MODEL=google/gemini-2.5-flash-lite
# 사진/동영상 감정 분석용 비전 모델
VITE_OPENROUTER_VISION_MODEL=minimax/minimax-m3
# 표지 이미지 생성 모델 (이미지당 약간의 비용)
VITE_OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image
